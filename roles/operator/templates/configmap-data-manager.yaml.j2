---

# A Data-Manager-compliant ConfigMap.
# This is deployed to the DM namespace and provides configuration material.
# The configMap must have the same name as the application CRD,
# e.g. 'datavisualisations.squonk.it'.
#
# The 'data' section provides a 'dm-app.config' key
# with a value that's essentially a Python Configparser file using '='
# as key/value delimiter.
#
# It also provides a 'dm-app.template' key - a JSON string (loaded by the
# Data Manager with json.loads()) describing the user-definable application
# variables a client can select. It is hard-coded for now.

kind: ConfigMap
apiVersion: v1
metadata:
  name: datavisualisations.squonk.it
  namespace: {{ svo_dm_namespace }}
data:
  dm-app.config: |
    [cost]
    # Charging configuration
    cost = {{ svo_cost_cost }}
    period = {{ svo_cost_period }}
    unit = PxGi
    pro rata = yes
  dm-app.template: |
    {
      "title": "The VizOperator Template",
      "description": "User-definable application variables for the viz application operator",
      "type": "object",
      "required": ["versions"],
      "properties": {
        "versions": {
          "title": "Viz application versions",
          "description": "The choice of viz application version.",
          "type": "string",
          "enum": ["0.1.4"]
        },
        "memory": {
          "title": "Memory request",
          "description": "The viz container memory request.",
          "type": "string",
          "enum": ["1Gi", "2Gi", "3Gi", "4Gi", "6Gi", "8Gi"],
          "default": "1Gi"
        },
        "cpu": {
          "title": "CPU request",
          "description": "The viz container CPU request, an integer, in units of whole CPU",
          "type": "string",
          "enum": ["1", "2"],
          "default": "1"
        }
      }
    }
